# AstraSRE environment variables
# Copy this to .env and fill in values

# Optional: Groq free API key for LLM incident reports
# Sign up free at https://console.groq.com (no credit card required)
# Without this, Ollama or template fallback is used automatically
GROQ_API_KEY=

# Optional: Ollama model (default: llama3.2:3b)
# Install Ollama: https://ollama.ai | then run: ollama pull llama3.2:3b
OLLAMA_MODEL=llama3.2:3b
